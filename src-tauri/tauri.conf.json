{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aspen",
  "version": "0.4.1",
  "identifier": "com.zhangzhengyi.aspen",
  "build": {
    "beforeDevCommand": "pnpm prepare:slang-server-bundle && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm prepare:tauri-build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aspen",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "decorations": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/0xtaruhi/aspen/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMzFFQzIwNDFGNTI5RDIKUldUU0tmVkJJT3d4bnpJVjFtd0h6ZW9lRzEva2k0T2E1UEFiMy9QMFhVVG13WlZCOWdaUE1WVFIK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "app", "dmg", "nsis"],
    "macOS": {
      "signingIdentity": "-",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerHooks": "windows/driver-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
