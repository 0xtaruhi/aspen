{
  "name": "aspen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "prepare:yosys-bundle": "node scripts/prepare-yosys-bundle.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/vue-table": "^8.21.3",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "@vueuse/core": "^13.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.544.0",
    "monaco-editor": "^0.55.1",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "vue3-grid-layout": "^1.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.4",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "~5.6.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,vue,json,css,scss,md,yml,yaml}": "prettier --write",
    "src-tauri/src/**/*.rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --"
  }
}
