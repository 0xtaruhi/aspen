{
  "name": "aspen",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "prepare:tauri-build": "node scripts/prepare-tauri-build.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "generate:zh-tw-locale": "node scripts/generate-zh-tw-locale.mjs",
    "generate:zh-tw-manuals": "node scripts/generate-zh-tw-manuals.mjs",
    "generate:icons": "bash scripts/generate-app-icon.sh",
    "prepare:yosys-bundle": "node scripts/prepare-yosys-bundle.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-table": "^8.21.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@vueuse/core": "^13.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "lucide-vue-next": "^0.544.0",
    "marked": "^18.0.0",
    "monaco-editor": "^0.55.1",
    "reka-ui": "^2.9.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4",
    "vue3-grid-layout": "^1.0.0",
    "wavedrom": "^3.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "opencc-js": "^1.0.5",
    "prettier": "^3.8.1",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.1",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,vue,json,css,scss,md,yml,yaml}": "prettier --write",
    "src-tauri/src/**/*.rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --"
  }
}
